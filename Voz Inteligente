        "            \"Verifica que Drive esté montado y la ruta sea correcta.\"\n",
        "        )\n",
        "\n",
        "    # Recorrer cada subcarpeta (cada una = una clase/etiqueta)\n",
        "    carpetas = sorted([\n",
        "        d for d in os.listdir(ruta_base)\n",
        "        if os.path.isdir(os.path.join(ruta_base, d))\n",
        "    ])\n",
        "\n",
        "    if len(carpetas) == 0:\n",
